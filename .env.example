# ─── Neo-Dock Server ─────────────────────────────────────────────────────────
NEO_DOCK_PORT=3000
NEO_DOCK_API_KEY=change-me-to-a-secure-random-key

# ─── Chef-API Connection ────────────────────────────────────────────────────
CHEF_API_URL=http://chef-api:4242
CHEF_API_KEY=your-chef-api-key

# Multi-server mode (optional — PR #17):
# CHEF_SERVERS=local=http://localhost:4242,remote=http://10.13.13.2:4242
# Per-server API keys (falls back to CHEF_API_KEY if not set):
# CHEF_API_KEY_LOCAL=key-for-local
# CHEF_API_KEY_REMOTE=key-for-remote

# ─── Loki (Log Aggregation) ─────────────────────────────────────────────────
LOKI_URL=http://loki:3100

# ─── Poll Intervals (seconds) ───────────────────────────────────────────────
POLL_SYSTEM=2
POLL_DOCKER=5
POLL_SERVICES=30
POLL_GITHUB=60
POLL_EMAIL=30
POLL_LOGS=2
POLL_CRON=10

# ─── Services Monitoring ────────────────────────────────────────────────────
# Comma-separated systemd service names to monitor via chef-api
MONITORED_SERVICES=nginx,docker,ssh,fail2ban
